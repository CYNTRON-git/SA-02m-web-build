# -*- sudo rules for sa02m-flasher -*-
# Минимально необходимые команды: systemctl и fuser для координации доступа к RS-485.
# Все остальное — под правами пользователя sa02m-flasher (группа dialout для /dev/ttyS*).
#
# Внимание: устанавливать с правами 0440, см. scripts/04-flasher.sh.
Cmnd_Alias SA02M_FLASHER = \
    /bin/systemctl, \
    /usr/bin/systemctl, \
    /bin/fuser, \
    /usr/bin/fuser

sa02m-flasher ALL=(root) NOPASSWD: SA02M_FLASHER
Defaults:sa02m-flasher !requiretty
