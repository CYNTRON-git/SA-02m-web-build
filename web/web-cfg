    cat > "$WEB_ROOT/cgi-bin/apply.cgi" <<'EOF'
#!/bin/bash
echo "Content-type: text/html; charset=utf-8"
echo "Location: /cgi-bin/index.cgi?status=applied"
echo ""

read -r POST_DATA
IP=$(echo "$POST_DATA" | sed -n 's/^.*ip=\([^&]*\).*$/\1/p' | sed 
's/%\([0-9A-F][0-9A-F]\)/\\x\1/gI' | xargs -0 printf '%b')
NETMASK=$(echo "$POST_DATA" | sed -n 's/^.*netmask=\([^&]*\).*$/\1/p' | sed 
's/%\([0-9A-F][0-9A-F]\)/\\x\1/gI' | xargs -0 printf '%b')
GATEWAY=$(echo "$POST_DATA" | sed -n 's/^.*gateway=\([^&]*\).*$/\1/p' | sed 
's/%\([0-9A-F][0-9A-F]\)/\\x\1/gI' | xargs -0 printf '%b')
DNS=$(echo "$POST_DATA" | sed -n 's/^.*dns=\([^&]*\).*$/\1/p' | sed 
's/%\([0-9A-F][0-9A-F]\)/\\x\1/gI' | xargs -0 printf '%b')
DATETIME=$(echo "$POST_DATA" | sed -n 's/^.*datetime=\([^&]*\).*$/\1/p' | sed 
's/%\([0-9A-F][0-9A-F]\)/\\x\1/gI' | xargs -0 printf '%b')
TIMEZONE=$(echo "$POST_DATA" | sed -n 's/^.*timezone=\([^&]*\).*$/\1/p' | sed 
's/%\([0-9A-F][0-9A-F]\)/\\x\1/gI' | xargs -0 printf '%b')

# Обновление часового пояса
if timedatectl list-timezones | grep -qx "$TIMEZONE"; then
    timedatectl set-timezone "$TIMEZONE" || {
        echo "Location: /cgi-bin/index.cgi?status=error_tz"
        exit 0
    }
else
    echo "Location: /cgi-bin/index.cgi?status=error_tz"
    exit 0
fi

# Установка времени
if date -d "$DATETIME" &>/dev/null; then
    if sudo /bin/date -s "$(date --date="$DATETIME" '+%Y-%m-%d %H:%M:%S %z')" >/dev/null 2>&1; 
	then
        sudo /sbin/hwclock -w
        echo "Location: /cgi-bin/index.cgi?status=time_updated"
    else
        echo "Location: /cgi-bin/index.cgi?status=error_time"
    fi
else
    echo "Location: /cgi-bin/index.cgi?status=error_time"
fi
{
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Применение новых параметров:"
echo "IP: $IP"
echo "Netmask: $NETMASK"
echo "Gateway: $GATEWAY"
echo "DNS: $DNS"
} >> /var/log/sa02m_install.log 2>&1

exit 0
EOF

