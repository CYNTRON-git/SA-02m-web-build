    # Конфигурация Nginx (добавлены важные директивы)
    log "INFO" "Генерация конфига Nginx"
    cat > /etc/nginx/sites-available/network.conf <<EOF
    # Веб-интерфейс настроек (порт 9999)
    server {
    listen 9999;       # Только IPv4
    server_name _;
    root ${WEB_ROOT};
    
    index index.html index.cgi;
    autoindex off;
    
    # Базовые настройки безопасности
    server_tokens off;
    charset utf-8;
    
    # Обработка статических файлов
    location /static/ {
        alias ${WEB_ROOT}/static/;
        expires 30d;
        access_log off;
        add_header Cache-Control "public";
    }

    # Обработка CGI-скриптов
    location /cgi-bin/ {
        gzip off;
        fastcgi_pass unix:/var/run/fcgiwrap.socket;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
    }

    # Перенаправление корневого URL
    location = / {
        return 302 /cgi-bin/index.cgi;
    }

    # Запрет доступа к скрытым файлам
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
	
}
EOF

