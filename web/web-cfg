#!/bin/bash
# Полная установка и настройка сервера СА-02м версия 12.0
# Дата последнего изменения: 02.04.2025

### Глобальные параметры ###
LOG_FILE="/var/log/sa02m_install.log"
NET_LOG="/var/log/fix-eth.log"
WEB_ROOT="/var/www/network_config"
PORT=9999
TMP_ROOT="/tmp/sa02m_install"
IP_ADDRESS="192.168.1.136"
NETMASK="255.255.255.0"
GATEWAY="192.168.1.1"
DNS_SERVERS="77.88.8.8 77.88.8.1"
NET_IFACE="eth0"
AUTH_FILE="/etc/nginx/.htpasswd"

### Функции ###

log() {
    local level=$1
    local message=$2
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo -e "[${timestamp}] [${level}] ${message}" | tee -a "$LOG_FILE"
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        log "ERROR" "Требуются права root! Запустите скрипт с sudo."
        exit 1
    fi
}

error_exit() {
    log "ERROR" "Критическая ошибка в строке $1: $2"
    exit 1
}

check_eth0() {
    if ip link show ${NET_IFACE} >/dev/null 2>&1; then
        local link_state=$(cat /sys/class/net/${NET_IFACE}/carrier 2>/dev/null)
        if [ "$link_state" -eq 1 ]; then
            return 0
        fi
    fi
    return 1
}

configure_network() {
    log "INFO" "Настройка сетевого интерфейса ${NET_IFACE}"
    
    log "INFO" "Запись параметров в eth0.conf"
    CFG_FILE="/etc/network/interfaces.d/eth0.conf"
    cat > ${CFG_FILE} <<EOF
auto ${NET_IFACE}
iface ${NET_IFACE} inet static
    address ${IP_ADDRESS}
    netmask ${NETMASK}
    gateway ${GATEWAY}
    dns-nameservers ${DNS_SERVERS}
	#       hwaddress ether 02:53:8B:00:D4:30
	#       pre-up /sbin/ifconfig eth0 mtu 3838
        post-up /home/klogic/adjust-eth0 || /bin/true
        post-up /sbin/ifconfig eth0 promisc # Альтернатива некоторым оптимизациям
		 # Разрешение портов
    ufw allow 80/tcp     # lighttpd
    ufw allow 9999/tcp  # Настройки
    ufw allow 8043/tcp  # MasterSCADA4D
    ufw --force enable
EOF

	 log "INFO" "Создаем правило для автоматического восстановления"
	sudo tee /etc/udev/rules.d/99-lan-recovery.rules > /dev/null <<EOF
ACTION=="add", SUBSYSTEM=="net", KERNEL=="eth0", RUN+="/usr/bin/systemctl restart 
fix-eth.service"
EOF
	 
    systemctl restart networking.service >> "$LOG_FILE" 2>&1 || {
        log "ERROR" "Ошибка перезапуска сети!"
        return 1
    }

    cat > /usr/local/bin/fix-eth.sh <<EOF
#!/bin/bash
INTERFACE="eth0"
LOG_FILE="/var/log/fix-eth.log"
MAX_RETRIES=2
DELAY=3

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> $LOG_FILE
}

check_interface() {
    # Проверка состояния интерфейса и IP через ifconfig
    /sbin/ifconfig $INTERFACE | grep -q "UP" && \
    /sbin/ifconfig $INTERFACE | grep -q "inet "
}

reset_interface() {
    log "Начало сброса интерфейса (net-tools)"
    /sbin/ifconfig $INTERFACE down
    sleep $DELAY
    /sbin/ifconfig $INTERFACE up
    sleep $DELAY
}

main() {
    log "Запуск процедуры восстановления (net-tools)"
    
    # Проверка физического подключения через mii-tool
    if ! /sbin/mii-tool $INTERFACE 2>/dev/null | grep -q "link ok"; then
        log "Кабель отключен, выход"
        return 1
    fi

    # Основной цикл восстановления
    for ((i=1; i<=$MAX_RETRIES; i++)); do
        reset_interface
        
        if check_interface; then
            log "Интерфейс $INTERFACE успешно восстановлен (ifconfig)"
            return 0
        else
            log "Попытка $i/$MAX_RETRIES не удалась"
        fi
    done
    
    log "Все попытки восстановления исчерпаны"
    return 1
}

main
EOF

    cat > /etc/systemd/system/fix-eth.service <<EOF
[Unit]
Description=Служба восстановления сети ${NET_IFACE}
After=network.target
Conflicts=shutdown.target
StartLimitIntervalSec=60
StartLimitBurst=2

[Service]
Type=oneshot
ExecStart=/usr/local/bin/fix-eth.sh
TimeoutSec=40
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

