sed -i '/[::]/d' /etc/nginx/sites-available/default
chmod 777 "$LOG_FILE"
log "INFO" "1. Обновление системы"
apt-get update >> "$LOG_FILE" 2>&1 || error_exit $LINENO "Ошибка обновления пакетов"
# apt-get -y upgrade >> "$LOG_FILE" 2>&1 || error_exit $LINENO "Ошибка обновления системы"

log "INFO" "2. Установка пакетов"
apt-get -y install \
    usb-modeswitch \
	mc \
    libi2c-dev \
    libgpiod-dev \
    nginx \
    fcgiwrap \
    ethtool \
    net-tools \
	dialog \
    dos2unix \
    ipcalc >> "$LOG_FILE" 2>&1 || error_exit $LINENO "Ошибка установки пакетов"

log "INFO" "Настройка прав для управления временем"
echo "www-data ALL=(ALL) NOPASSWD: /bin/date, /sbin/hwclock" > /etc/sudoers.d/time-sync
chmod 440 /etc/sudoers.d/time-sync

chmod 755 "$WEB_ROOT/cgi-bin"/*.cgi

log "INFO" "3. Сетевая настройка"
if check_eth0; then
  log "Сетевая настройка"
else
    log "WARNING" "Сетевая настройка пропущена: интерфейс недоступен"
fi

log "INFO" "4. Системные параметры"
{
# Установите максимальную частоту 912 МГц вместо 1.2 ГГц
echo 912000 > /sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq
# Переназначение прерываний на определенные ядра
echo 1 > /proc/irq/$(cat /proc/interrupts | grep eth0 | awk '{print $1}' | tr -d :)/smp_affinity
# Отключите энергосбережение ядер
for i in /sys/devices/system/cpu/cpu*/online; do echo 1 > $i; done
# Установите conservative governor
echo "conservative" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor

# Оптимальные параметры для A40i
echo 20 | tee /sys/devices/system/cpu/cpufreq/conservative/down_threshold
echo 80 | tee /sys/devices/system/cpu/cpufreq/conservative/up_threshold

hostnamectl set-hostname SA-02m
systemctl disable serial-getty@ttyS0
systemctl mask serial-getty@ttyS0
systemctl disable serial-getty@ttyS1
systemctl mask serial-getty@ttyS1
systemctl enable getty@ttyGS0
timedatectl set-timezone Europe/Moscow
# Disable chronyd and timesyncd, no built-in NTP client is need
systemctl disable chronyd
systemctl mask chronyd
timedatectl set-ntp false

# Set UTC timezone
ln -s -f /usr/share/zoneinfo/UTC /etc/localtime
dpkg-reconfigure -f noninteractive tzdata
dpkg-reconfigure -f noninteractive tzdata
# Remove avahi-autoipd package
apt-get -y purge avahi-autoipd --autoremove
# Disable Network manager on static interfaces
sed -i 's/managed=true/managed=false/g' /etc/NetworkManager/NetworkManager.conf
# Disable weak ciphers and MACs
echo '' >> /etc/ssh/sshd_config
echo '# Allowed Ciphers and MACs' >> /etc/ssh/sshd_config
echo 'Ciphers aes256-gcm@openssh.com,aes128-gcm@openssh.com,chacha20-poly1305@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr' >> /etc/ssh/sshd_config
echo 'MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,hmac-sha2-512,hmac-sha2-256' >> /etc/ssh/sshd_config
# Set russian locale
locale-gen en_US.UTF-8 ru_RU.UTF-8
echo 'LANG=ru_RU.UTF-8' > /etc/default/locale
echo 'LANGUAGE=ru_RU.UTF-8' >> /etc/default/locale
echo 'LC_MESSAGES=ru_RU.UTF-8' >> /etc/default/locale
# Disable armbian-zram-config service and patch armbian-ramlog for correct lighttpd working
sed -i 's/ENABLED=true/ENABLED=false/g' /etc/default/armbian-zram-config
cp -f armbian-ramlog /usr/lib/armbian/
# Остановить службы
sudo systemctl stop apt-daily-upgrade.service
sudo systemctl stop apt-daily-upgrade.timer
sudo systemctl stop apt-daily.service
sudo systemctl stop apt-daily.timer

# Запретить автозапуск
sudo systemctl disable apt-daily-upgrade.service
sudo systemctl disable apt-daily-upgrade.timer
sudo systemctl disable apt-daily.service
sudo systemctl disable apt-daily.timer

# Дополнительно: заблокировать даже ручной запуск
sudo systemctl mask apt-daily-upgrade.service
sudo systemctl mask apt-daily-upgrade.timer
# Use resolvconf as DNS resovler
apt-get -y install resolvconf
echo '[main]' > /etc/NetworkManager/conf.d/rс.conf
echo 'rc-manager=resolvconf' >> /etc/NetworkManager/conf.d/rс.conf
rm -f /etc/resolv.conf
ln -s /run/resolvconf/resolv.conf /etc/resolv.conf
# Add user hmi
useradd -G users,www-data -s /bin/bash -p "$(openssl passwd -6 'HMI')" -m -d /home/hmi hmi
# CYNTRON SA-02m
sed -i '/^BOARD_NAME=/d' /etc/armbian-release
echo "BOARD_NAME=SA-02m" >> /etc/armbian-release
sed -i '/^VENDOR=/d' /etc/armbian-release
echo "VENDOR=CYNTRON" >> /etc/armbian-release
sed -i '/^BOARD=/d' /etc/armbian-image-release
echo "BOARD=SA-02m" >> /etc/armbian-image-release
sed -i '/^BOARD_NAME=/d' /etc/armbian-image-release
echo "BOARD_NAME=SA-02m" >> /etc/armbian-image-release
sed -i '/^VENDOR=/d' /etc/armbian-image-release
echo "VENDOR=CYNTRON" >> /etc/armbian-image-release

sudo ln -sf /dev/ttyS0 /dev/COM1
sudo ln -sf /dev/ttyS0 /dev/RS-485-0

sudo ln -sf /dev/ttyS3 /dev/COM2
sudo ln -sf /dev/ttyS3 /dev/RS-485-1

sudo ln -sf /dev/ttyS4 /dev/COM3
sudo ln -sf /dev/ttyS4 /dev/RS-485-2

sudo ln -sf /dev/ttyS5 /dev/COM4
sudo ln -sf /dev/ttyS5 /dev/RS-485-3

sudo ln -sf /dev/ttyS7 /dev/COM5
sudo ln -sf /dev/ttyS7 /dev/RS-485-4

# Create user and home directory
      useradd -G users,www-data -s /bin/bash -p `openssl passwd -3 HMI` -m -d /home/hmi hmi
} >> "$LOG_FILE" 2>&1

log "INFO" "5. Веб-интерфейс"
configure_web_interface

log "INFO" "6. Финализация установки"
{
echo "Установка завершена: $(date)"
echo "URL: http://${IP_ADDRESS}:${PORT}"
echo "Данные для входа:"
echo "Логин: admin"
echo "Пароль: cyntron"
echo ""
echo "=== Проверка статуса служб ==="
systemctl status nginx fcgiwrap.socket --no-pager
echo "=== Проверка открытых портов ==="
    ss -tulpn | grep -E ':80|:9999|:8043'
} | tee -a "$LOG_FILE"
log "INFO" "Проверка временных настроек:"
{
    echo "=== Timezone ==="
    timedatectl | grep "Time zone"
    echo "=== System time ==="
    date
    echo "=== RTC time ==="
    hwclock --show
} | tee -a "$LOG_FILE"
log "OK" "Установка успешно завершена!"
exit 0
