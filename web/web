# Полная установка и настройка сервера СА-02м версия 12.0
# Дата последнего изменения: 02.04.2025

### Глобальные параметры ###
LOG_FILE="/var/log/sa02m_install.log"
NET_LOG="/var/log/fix-eth.log"
WEB_ROOT="/var/www/network_config"
PORT=9999
TMP_ROOT="/tmp/sa02m_install"
IP_ADDRESS="192.168.1.136"
NETMASK="255.255.255.0"
GATEWAY="192.168.1.1"
DNS_SERVERS="77.88.8.8 77.88.8.1"
NET_IFACE="eth0"
AUTH_FILE="/etc/nginx/.htpasswd"

### Функции ###

log() {
    local level=$1
    local message=$2
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo -e "[${timestamp}] [${level}] ${message}" | tee -a "$LOG_FILE"
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        log "ERROR" "Требуются права root! Запустите скрипт с sudo."
        exit 1
    fi
}

error_exit() {
    log "ERROR" "Критическая ошибка в строке $1: $2"
    exit 1
}

check_eth0() {
    if ip link show ${NET_IFACE} >/dev/null 2>&1; then
        local link_state=$(cat /sys/class/net/${NET_IFACE}/carrier 2>/dev/null)
        if [ "$link_state" -eq 1 ]; then
            return 0
        fi
    fi
    return 1
}


configure_web_interface() {
    log "INFO" "Настройка веб-интерфейса"
    
    # Очистка и создание структуры каталогов
    rm -rf "$WEB_ROOT"
    mkdir -p "$WEB_ROOT/cgi-bin"
    mkdir -p "$WEB_ROOT/static"

    # GPIO для DO / пищалки / аварийного LED (редактируется под плату)
    if [ ! -f /etc/sa02m_hw.conf ]; then
        cat > /etc/sa02m_hw.conf <<'HWCONF'
# Номера GPIO для sysfs /sys/class/gpio/gpioN (СА-02м).
# Заполните целые номера линий для вашей платы; пусто = функция отключена в веб-интерфейсе.
SA02M_GPIO_DO=
SA02M_GPIO_BEEPER=
SA02M_GPIO_ALARM_LED=
HWCONF
        chmod 644 /etc/sa02m_hw.conf
        log "INFO" "Создан /etc/sa02m_hw.conf (шаблон GPIO)"
    fi
    
    # Создание файла перенаправления с правильными правами
    log "INFO" "Создание системы перенаправления"
    cat > "$WEB_ROOT/index.html" <<'EOF'
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="refresh" content="0; url=/cgi-bin/index.cgi">
    <title>Перенаправление</title>
</head>
<body>
    <h1>Перенаправление на панель управления</h1>
    <p>Если автоматическое перенаправление не сработало, <a 
href="/cgi-bin/index.cgi">нажмите здесь</a>.</p>
</body>
</html>
EOF

   
    chmod 755 "$WEB_ROOT/cgi-bin"/*.cgi 2>/dev/null
    
    # Настройка владельца
    chown -R www-data:www-data "$WEB_ROOT"
	# Добавить в секцию настройки прав для задания времени

    log "INFO" "Создание файла паролей"
    echo -n "admin:" | sudo tee "$AUTH_FILE" >/dev/null
    openssl passwd -apr1 cyntron | sudo tee -a "$AUTH_FILE" >/dev/null
    chmod 640 "$AUTH_FILE"
    chown www-data:www-data "$AUTH_FILE"
	


